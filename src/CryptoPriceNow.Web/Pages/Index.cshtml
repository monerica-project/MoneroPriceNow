@page
@model CryptoPriceNow.Pages.IndexModel
@{
    ViewData["Title"] = "MoneroPriceNow.com — Live XMR / USDT Prices";
}

<link rel="stylesheet" href="~/css/moneropricenow.css" asp-append-version="true" />

<div class="pair-label">Live XMR instant swap rates &nbsp;·&nbsp; No KYC &nbsp;·&nbsp; USDT (TRC20)</div>

<div class="price-hero">

    <!-- Center: Market Price (first in DOM = top on mobile) -->
    <div class="hero-center">
        <div class="hc-eyebrow">XMR / USDT</div>
        <div class="hc-price" id="heroMid">
            <span class="skel" style="width:180px;height:64px;border-radius:6px;display:inline-block"></span>
        </div>
        <div class="hc-badge">Market Price</div>
        <div class="hc-sub" id="heroMidSub"></div>
    </div>

    <!-- Left: Avg Buy -->
    <div class="hero-side hero-left">
        <div class="hs-label">Avg Buy Price</div>
        <div class="hs-price buy-color" id="heroAvgBuy">
            <span class="skel" style="width:120px;height:36px;border-radius:5px"></span>
        </div>
        <div class="hs-sub">
            <span class="hs-arrow buy-arr">▼</span>
            <span id="heroAvgBuyN">USDT → XMR · you pay per XMR</span>
        </div>
    </div>

    <!-- Right: Avg Sell -->
    <div class="hero-side hero-right">
        <div class="hs-label">Avg Sell Price</div>
        <div class="hs-price sell-color" id="heroAvgSell">
            <span class="skel" style="width:120px;height:36px;border-radius:5px"></span>
        </div>
        <div class="hs-sub">
            <span class="hs-arrow sell-arr">▲</span>
            <span id="heroAvgSellN">XMR → USDT · you receive per XMR</span>
        </div>
    </div>

</div>

<!-- Status bar -->
<div class="status-bar">
    <div class="pulse-dot"></div>
    <span id="lastUpdated">Fetching prices…</span>
    <div class="tick-track" id="tickTrack"></div>
    <div class="countdown-wrap">
        <div class="countdown-ring">
            <svg width="16" height="16" viewBox="0 0 16 16">
                <circle class="ring-bg" cx="8" cy="8" r="6" />
                <circle class="ring-fill" cx="8" cy="8" r="6" id="ringFill"
                        stroke-dasharray="37.7" stroke-dashoffset="0" />
            </svg>
        </div>
        <span id="countdownText">15s</span>
    </div>
</div>

<!-- Price table -->
<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th class="th-sort" data-sort="name">Exchange <span class="sort-arrow"></span></th>
                <th class="th-sort" data-sort="privacy">Privacy <span class="sort-arrow"></span></th>
                <th class="th-sort" data-sort="buy">Buy ($ per XMR) <span class="sort-arrow"></span></th>
                <th class="th-sort" data-sort="sell">Sell ($ per XMR) <span class="sort-arrow"></span></th>
                <th class="th-sort" data-sort="spread">Spread <span class="sort-arrow"></span></th>
                <th>Updated</th>
            </tr>
        </thead>
        <tbody id="pricesBody">
            <tr class="skel-row"><td><span class="skel skel-name"></span></td><td><span class="skel" style="width:20px;height:20px;border-radius:4px"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel" style="width:44px;height:14px;border-radius:4px;margin-left:auto"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name" style="width:110px"></span></td><td><span class="skel" style="width:20px;height:20px;border-radius:4px"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel" style="width:44px;height:14px;border-radius:4px;margin-left:auto"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name" style="width:75px"></span></td><td><span class="skel" style="width:20px;height:20px;border-radius:4px"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel" style="width:44px;height:14px;border-radius:4px;margin-left:auto"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name" style="width:95px"></span></td><td><span class="skel" style="width:20px;height:20px;border-radius:4px"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel" style="width:44px;height:14px;border-radius:4px;margin-left:auto"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name"></span></td><td><span class="skel" style="width:20px;height:20px;border-radius:4px"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel" style="width:44px;height:14px;border-radius:4px;margin-left:auto"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name" style="width:80px"></span></td><td><span class="skel" style="width:20px;height:20px;border-radius:4px"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel" style="width:44px;height:14px;border-radius:4px;margin-left:auto"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name" style="width:100px"></span></td><td><span class="skel" style="width:20px;height:20px;border-radius:4px"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel" style="width:44px;height:14px;border-radius:4px;margin-left:auto"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name" style="width:88px"></span></td><td><span class="skel" style="width:20px;height:20px;border-radius:4px"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel" style="width:44px;height:14px;border-radius:4px;margin-left:auto"></span></td><td><span class="skel skel-ts"></span></td></tr>
        </tbody>
    </table>
</div>

<!-- Explainer cards -->
<div class="explainer-section">
    <div class="explainer-card">
        <span class="ec-title">&#x25BC; Buy price — lower is better</span>
        The <strong>buy price</strong> is how many <strong>$USD (USDT)</strong> you must spend to receive <strong>1 XMR</strong>.
        A lower buy price means a cheaper exchange. The best buy is highlighted in green.
    </div>
    <div class="explainer-card">
        <span class="ec-title">&#x25B2; Sell price — higher is better</span>
        The <strong>sell price</strong> is how many <strong>$USD (USDT)</strong> you receive when you send <strong>1 XMR</strong>.
        A higher sell price means more value back. The best sell is highlighted in green.
    </div>
</div>

<!-- Disclosure -->
<div class="disclosure">
    Prices are indicative floating rates.&nbsp;&nbsp;
    Some links on this page may be affiliate links in which we may earn a commission.
</div>

<!-- Sponsor section -->
<div class="sponsor-section" id="sponsorSection">
    <div class="sponsor-section-title">&#x2605; Sponsors</div>
    <div id="sponsorTiers"></div>
</div>

<script src="~/js/moneropricenow.js" asp-append-version="true"></script>
