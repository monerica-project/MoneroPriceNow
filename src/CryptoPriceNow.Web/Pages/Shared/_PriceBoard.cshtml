@using System.Globalization
@using CryptoPriceNow.Web.Models
@model PriceBoardView
@{
    var initialPricesJson = (ViewData["InitialPricesJson"] as string) ?? "[]";
    var minValid = Model.MinValidPrice.ToString(CultureInfo.InvariantCulture);
}

<link rel="stylesheet" href="~/css/pricechart.css" asp-append-version="true" />

<!-- Pair tabs (plain links — fully indexable, no JS) -->
<nav class="pair-tabs" aria-label="Trading pair">
    @foreach (var p in PairCatalog.All)
    {
        var active = p.Slug == Model.Slug ? " pair-tab-active" : "";
        <a class="pair-tab@(active)" href="@p.Url"
           aria-current="@(p.Slug == Model.Slug ? "page" : null)">XMR / @p.QuoteLabel</a>
    }
</nav>

<div class="price-hero">

    <!-- Center: Market Price (first in DOM = top on mobile) -->
    <div class="hero-center">
        <div class="hc-eyebrow">XMR / @Model.QuoteLabel</div>
        <div class="hc-price" id="heroMid">
            <span class="skel skel-hero-mid"></span>
        </div>
        <div class="hc-badge">Market Price</div>
        <div class="hc-sub" id="heroMidSub"></div>
    </div>

    <!-- Left: Avg Buy -->
    <div class="hero-side hero-left">
        <div class="hs-label">Avg Buy Price</div>
        <div class="hs-price buy-color" id="heroAvgBuy">
            <span class="skel skel-hero-side"></span>
        </div>
        <div class="hs-sub">
            <span class="hs-arrow buy-arr">▼</span>
            <span id="heroAvgBuyN">@Model.QuoteLabel → XMR · you pay per XMR</span>
        </div>
    </div>

    <!-- Right: Avg Sell -->
    <div class="hero-side hero-right">
        <div class="hs-label">Avg Sell Price</div>
        <div class="hs-price sell-color" id="heroAvgSell">
            <span class="skel skel-hero-side"></span>
        </div>
        <div class="hs-sub">
            <span class="hs-arrow sell-arr">▲</span>
            <span id="heroAvgSellN">XMR → @Model.QuoteLabel · you receive per XMR</span>
        </div>
    </div>

</div>

<!-- Status bar -->
<div class="status-bar">
    <div class="pulse-dot"></div>
    <span id="lastUpdated">Fetching prices…</span>
    <div class="tick-track" id="tickTrack"></div>
    <span class="session-delta" id="sessionDelta"></span>
    <div class="countdown-wrap">
        <div class="countdown-ring">
            <svg width="16" height="16" viewBox="0 0 16 16">
                <circle class="ring-bg" cx="8" cy="8" r="6" />
                <circle class="ring-fill" cx="8" cy="8" r="6" id="ringFill"
                        stroke-dasharray="37.7" stroke-dashoffset="0" />
            </svg>
        </div>
        <span id="countdownText">15s</span>
    </div>
</div>

<!-- Quick converter -->
<div class="converter">
    <div class="conv-title">Quick Convert</div>
    <div class="conv-row">
        <div class="conv-field">
            <label for="convUsd">@Model.QuoteLabel</label>
            <input type="number" id="convUsd" inputmode="decimal" step="any" min="0" placeholder="0.00" autocomplete="off" />
        </div>
        <div class="conv-swap" aria-hidden="true">⇄</div>
        <div class="conv-field">
            <label for="convXmr">XMR</label>
            <input type="number" id="convXmr" inputmode="decimal" step="any" min="0" placeholder="0.000000" autocomplete="off" />
        </div>
    </div>
    <div class="conv-note" id="convNote">Based on current market price</div>
</div>

<!-- Price table -->
<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th class="th-sort" data-sort="name">Exchange <span class="sort-arrow"></span></th>
                <th class="th-sort" data-sort="privacy">Privacy <span class="sort-arrow"></span></th>
                <th class="th-sort" data-sort="buy">Buy (@Model.PriceUnitLabel) <span class="sort-arrow"></span></th>
                <th class="th-sort" data-sort="sell">Sell (@Model.PriceUnitLabel) <span class="sort-arrow"></span></th>
                <th class="th-sort" data-sort="spread">Spread <span class="sort-arrow"></span></th>
                <th class="th-sort" data-sort="minamt">Min Amount <span class="sort-arrow"></span></th>
                <th>Updated</th>
            </tr>
        </thead>
        <tbody id="pricesBody">
            <tr class="skel-row"><td><span class="skel skel-name"></span></td><td><span class="skel skel-privacy"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-spread"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name"></span></td><td><span class="skel skel-privacy"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-spread"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name"></span></td><td><span class="skel skel-privacy"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-spread"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name"></span></td><td><span class="skel skel-privacy"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-spread"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name"></span></td><td><span class="skel skel-privacy"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-spread"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name"></span></td><td><span class="skel skel-privacy"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-spread"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name"></span></td><td><span class="skel skel-privacy"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-spread"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-ts"></span></td></tr>
            <tr class="skel-row"><td><span class="skel skel-name"></span></td><td><span class="skel skel-privacy"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-spread"></span></td><td><span class="skel skel-num"></span></td><td><span class="skel skel-ts"></span></td></tr>
        </tbody>
    </table>
</div>

<!-- Price history chart (hidden until /api/history confirms data is available) -->
<div class="chart-section" id="chartSection" hidden>
    <div class="chart-head">
        <div class="chart-title-wrap">
            <span class="chart-title">Price History</span>
            <span class="chart-trend" id="chartTrend"></span>
        </div>
        <div class="chart-ranges" id="chartRanges" role="group" aria-label="Chart time range">
            <button type="button" class="chart-range-btn chart-range-active" data-range="1h">1h</button>
            <button type="button" class="chart-range-btn" data-range="4h" hidden>4h</button>
            <button type="button" class="chart-range-btn" data-range="12h" hidden>12h</button>
            <button type="button" class="chart-range-btn" data-range="1d" hidden>1d</button>
            <button type="button" class="chart-range-btn" data-range="3d" hidden>3d</button>
            <button type="button" class="chart-range-btn" data-range="7d" hidden>7d</button>
            <button type="button" class="chart-range-btn" data-range="30d" hidden>30d</button>
        </div>
    </div>
    <div class="chart-wrap">
        <canvas id="priceChart" aria-label="XMR/@Model.QuoteLabel buy, sell, and market price history chart" role="img"></canvas>
        <div class="chart-empty" id="chartEmpty" hidden>Collecting price history… check back in a few minutes.</div>
    </div>
    <div class="chart-note">
        Averages across all listed exchanges · <span class="chart-key chart-key-buy">Buy</span> ·
        <span class="chart-key chart-key-sell">Sell</span> ·
        <span class="chart-key chart-key-market">Market</span> · auto-refreshing
    </div>
</div>

<!-- Privacy legend -->
<div class="privacy-legend">
    <span class="pl-title">Privacy levels:</span>
    <span class="pl-item"><span class="privacy-badge privacy-A">A</span> No logs, never KYC</span>
    <span class="pl-sep">·</span>
    <span class="pl-item"><span class="privacy-badge privacy-B">B</span> Minimal logs, KYC only if suspicious</span>
    <span class="pl-sep">·</span>
    <span class="pl-item"><span class="privacy-badge privacy-C">C</span> Some logs, KYC likely for larger amounts</span>
    <span class="pl-sep">·</span>
    <span class="pl-item"><span class="privacy-badge privacy-V">V</span> Varies by provider</span>
</div>


<!-- Explainer cards -->
<div class="explainer-section">
    <div class="explainer-card">
        <span class="ec-title">&#x25BC; Buy price — lower is better</span>
        The <strong>buy price</strong> is how much <strong>@Model.QuoteLabel</strong> you must spend to receive <strong>1 XMR</strong>.
        A lower buy price means a cheaper exchange. The best buy is highlighted in green.
    </div>
    <div class="explainer-card">
        <span class="ec-title">&#x25B2; Sell price — higher is better</span>
        The <strong>sell price</strong> is how much <strong>@Model.QuoteLabel</strong> you receive when you send <strong>1 XMR</strong>.
        A higher sell price means more value back. The best sell is highlighted in green.
    </div>
</div>

<aside class="xmr-mmc-cta">
    <p>
        Want market cap data comparing Monero to other coins?
        <a href="https://moneromarketcap.com" rel="noopener">View full market data on MoneroMarketCap →</a>
    </p>
</aside>

<!-- Disclosure -->
<div class="disclosure">
    <strong>MoneroPriceNow is for informational purposes only.</strong> We are a price aggregator — we do not custody, hold, or transmit funds, and we do not execute or facilitate trades. All swaps are carried out directly by the third-party exchanges listed here, under their own terms.<br>
    Prices are indicative floating rates on instant swaps and may differ at execution.&nbsp;&nbsp;
    Some links on this page may be affiliate links from which we may earn a commission.
</div>

<!-- Sponsor section -->
<div class="sponsor-section" id="sponsorSection">
    <div class="sponsor-section-title">&#x2605; Sponsors</div>
    <div id="sponsorTiers"></div>
</div>

<script>
    // Per-page pair config — read by moneropricenow.js and pricechart.js.
    window.__PAIR__ = {
        base: "@Model.Base",
        apiQuote: "@Model.ApiQuote",
        historyPair: "@Model.HistoryPair",
        quoteLabel: "@Model.QuoteLabel",
        symbol: "@Model.Symbol",
        suffix: "@Model.Suffix",
        decimals: @Model.Decimals,
        minValidPrice: @minValid,
        isUsd: @(Model.IsUsd ? "true" : "false")
    };
    window.__INITIAL_PRICES__ = @Html.Raw(initialPricesJson);
</script>
<script src="~/js/moneropricenow.js" asp-append-version="true"></script>
<script src="~/lib/chartjs/chart.umd.min.js" asp-append-version="true"></script>
<script src="~/js/pricechart.js" asp-append-version="true"></script>

<style>
    /* Pair tabs — minimal, self-contained. Move into your main CSS later if you prefer. */
    .pair-tabs {
        display: flex;
        gap: .4rem;
        justify-content: center;
        flex-wrap: wrap;
        margin: 0 auto 1rem;
        max-width: 100%;
    }
    .pair-tab {
        display: inline-block;
        padding: .35rem .9rem;
        border-radius: 999px;
        font: 600 .85rem/1 var(--mono, ui-monospace, monospace);
        letter-spacing: .02em;
        text-decoration: none;
        color: var(--text-muted, #8a7a6a);
        border: 1px solid rgba(242, 104, 34, .25);
        background: transparent;
        transition: background .15s, color .15s, border-color .15s;
    }
    .pair-tab:hover {
        color: var(--text, #e8dfd0);
        border-color: rgba(242, 104, 34, .55);
    }
    .pair-tab-active {
        color: #1a1208;
        background: var(--xmr-orange2, #ff8c3a);
        border-color: var(--xmr-orange2, #ff8c3a);
    }
</style>
